# xqshare 服务端环境变量配置
# 复制此文件为 .env 并修改配置
# cp .env.server.example .env

# ==================== 服务配置 ====================
# 服务监听端口
XQSHARE_PORT=18812

# ==================== QMT 配置 ====================
# QMT 客户端 userdata_mini 目录路径
QMT_USERDATA_PATH=C:\QMT\userdata_mini

# 默认资金账号（可选）
QMT_ACCOUNT_ID=你的资金账号

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== Tailscale tsnet sidecar ====================
# Optional: expose xqshare-server to a Tailscale tailnet through tailscale-proxy.
# Recommended server bind address when using the sidecar:
#   python -m xqshare.server --host 127.0.0.1 --port 18812
#
# Tailscale auth key. You can also use TS_AUTHKEY.
XQSHARE_TS_AUTHKEY=

# Node name shown in the tailnet.
XQSHARE_TS_HOSTNAME=xqshare-server

# Persistent tsnet state directory. Keep this across restarts.
XQSHARE_TS_STATE_DIR=./tsnet-state

# Port exposed inside the tailnet.
XQSHARE_TS_LISTEN_PORT=18812

# Local xqshare-server target.
XQSHARE_TS_TARGET_HOST=127.0.0.1
XQSHARE_TS_TARGET_PORT=18812
XQSHARE_TS_EPHEMERAL=false
XQSHARE_TS_UP_TIMEOUT=60s

# Set to 1 to let python -m xqshare.server start the Tailscale sidecar automatically.
XQSHARE_TAILSCALE=1
