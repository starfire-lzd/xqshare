# xqshare 客户端环境变量配置
# 复制此文件为 .env 并修改配置
# cp .env.client.example .env

# ==================== 连接配置 ====================
# 服务端地址
XQSHARE_REMOTE_HOST=192.168.1.100

# Tailscale mode example:
# XQSHARE_REMOTE_HOST=xqshare-server

# 服务端端口
XQSHARE_REMOTE_PORT=18812

# ==================== Tailscale 自动连接 ====================
# Set to 1 to let XtQuantRemote/xtdata/xttrader start a local Tailscale client sidecar.
XQSHARE_TAILSCALE=1

# Tailnet service name or 100.x IP exposed by the server sidecar.
XQSHARE_TS_TARGET_HOST=xqshare-server
XQSHARE_TS_TARGET_PORT=18812

# Local address used by Python client after the sidecar starts.
XQSHARE_TS_LOCAL_HOST=127.0.0.1
XQSHARE_TS_LOCAL_PORT=18812

# Optional auth key for first login on this client. You can also use TS_AUTHKEY.
XQSHARE_TS_AUTHKEY=
XQSHARE_TS_STATE_DIR=./tsnet-state-client

# ==================== 认证配置 ====================
# 客户端 ID（对应 clients.yaml 中的配置）
XQSHARE_CLIENT_ID=enterprise-user

# 客户端密钥
XQSHARE_CLIENT_SECRET=your-secret-here

# ==================== QMT 配置 ====================
# QMT 客户端 userdata_mini 目录路径
QMT_USERDATA_PATH=C:\QMT\userdata_mini

# 资金账号
QMT_ACCOUNT_ID=你的资金账号
